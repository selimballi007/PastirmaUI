# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git (it contains secrets)
# ===========================================

# -------------------------------------------
# API Configuration
# -------------------------------------------

# Backend API URL (client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:5296/api/

# Backend API URL (server-side only - for Server Actions)
# If not set, falls back to NEXT_PUBLIC_API_URL
API_URL=http://localhost:5296/api/

# Internal backend URL for production (Railway/Docker networking)
# Used for same-domain API proxy in production
# Example: pastirma-api.railway.internal
# BACKEND_INTERNAL_URL=

# -------------------------------------------
# Site Branding (per customer deployment)
# -------------------------------------------

# Your domain URL (with https://)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brand/Company name
NEXT_PUBLIC_SITE_NAME=Pastırma

# Site description for SEO
NEXT_PUBLIC_SITE_DESCRIPTION=Türkiye'nin en kaliteli pastırma ve şarküteri ürünlerini keşfedin. Hızlı teslimat, güvenli alışveriş.

# Open Graph image URL for social media shares (1200x630 recommended)
# Can be a Cloudinary URL or any public image URL
NEXT_PUBLIC_OG_IMAGE_URL=https://your-domain.com/og-image.jpg

# -------------------------------------------
# Cloudflare Turnstile (CAPTCHA)
# -------------------------------------------

# Site key from Cloudflare Turnstile dashboard
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Set to 'true' to disable Turnstile in development (NOT for production!)
# NEXT_PUBLIC_DISABLE_TURNSTILE=true

# -------------------------------------------
# Cloudinary (Image hosting)
# -------------------------------------------

# Your Cloudinary cloud name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
